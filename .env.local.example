# 中转站端点（必填，OpenAI 兼容的 /v1/images/* 接口）
# 部署时改成你自己的服务地址
GPT_IMAGE_ENDPOINT=https://your-provider.example.com/v1/images/generations
GPT_IMAGE_EDITS_ENDPOINT=https://your-provider.example.com/v1/images/edits

# 中转站 API key（必填）
GPT_IMAGE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# 模型名（按你的服务支持的填写）
GPT_IMAGE_MODEL=gpt-image-1

# Supabase（必填，supabase.com 创建一个项目后从 Project Settings > API 拿）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Supabase service_role（运维用，绕过 RLS，**仅服务端**使用，绝对不要 NEXT_PUBLIC_ 暴露）
# 拿法：Supabase Dashboard → Project Settings → API → service_role
# 这个 key 走的是 SECURITY DEFINER 路径（兑换扣费 / 兑换码插入 / 硬清理 cron），
# **绝不能**提交到 git、暴露给浏览器、放进任何前端代码路径。
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxx

# Cron 鉴权（任取一串 32 字节随机串）
# Vercel Cron 调 /api/cron/* 时会在 Authorization 头带这个
# 生成：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=replace-me-with-random-32-byte-hex

# 兑换码脚本：scripts/generate-codes.ts 用 service_role 写 redemption_codes
# 用法：npx tsx scripts/generate-codes.ts --amount 100 --count 10 [--note "..."] [--expires "2026-12-31"]
# 自动读 .env.local 里的 NEXT_PUBLIC_SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY

# 客服联系方式（在 /redeem 页「关于兑换码」卡展示，二选一即可）
# 留空则显示「未配置」提示——上线前必须填一个
SUPPORT_WECHAT=
SUPPORT_EMAIL=

# 管理员识别（个人项目用 env 列 UUID 最简单）
# 把你的 user.id 填进去（去 /me 页可以一键复制），多个管理员用英文逗号分隔
# ADMIN_USER_IDS=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# ADMIN_USER_IDS=uuid1,uuid2
